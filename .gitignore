# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.python-version

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/

# ---------------------------------------------------------------------------
# ohmo / OpenHarness runtime artifacts inside our in-repo workspaces.
# Persona / skills / plugins / god.md ARE committed. Runtime and secrets are not.
# ---------------------------------------------------------------------------
workspaces/*/sessions/
workspaces/*/logs/
workspaces/*/attachments/
workspaces/*/state.json
workspaces/*/gateway-restart-notice.json

# Anything resembling credentials, anywhere.
**/.credentials*
**/auth.json
**/*.secret
**/*.token

# ---------------------------------------------------------------------------
# Shared run state produced by the orchestrator + hooks
# ---------------------------------------------------------------------------
state/cascade-trace.jsonl
state/.last-run/

# Per-repo OpenHarness config dir the orchestrator materializes at launch.
# Contains a generated settings.json (with provider profile + mcp_servers),
# an agents/ dir with one AgentDefinition per teammate, and session state.
# Regenerated every launch; never commit.
state/.openharness/

# ---------------------------------------------------------------------------
# Mock MCP server working copy (persisted mocks regenerate on boot if missing)
# ---------------------------------------------------------------------------
tools/mock_mcp/.data/

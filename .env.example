# ----------------------------------------------------------------------------
# the-gooning-company — local environment template.
#
# Copy to `.env` (gitignored) and fill in real values on your machine.
# Orchestrator reads `.env` via python-dotenv before starting anything.
#
# Secrets: never commit this with real values. `.env` is gitignored; keep it so.
# ----------------------------------------------------------------------------

# OpenAI API key. Used by the OpenAI-compatible provider profile the
# orchestrator writes into state/.openharness/settings.json.
# Rotate at https://platform.openai.com/api-keys if you ever leak it.
OPENAI_API_KEY=sk-proj-replace-me

# Default model (used by every agent unless overridden per workspace).
# Any OpenAI-served model id works — e.g. gpt-5.4, gpt-4.1, gpt-4o-mini.
GOONING_MODEL=gpt-5.4

# Base URL for the OpenAI-compatible API. Change this if you route through
# OpenRouter / Azure / a local gateway. Leave default to hit OpenAI directly.
OPENAI_BASE_URL=https://api.openai.com/v1

# Mock MCP server bind address. Agents connect via workspaces/_shared/mcp.json
# which must match.
GOONING_MCP_HOST=127.0.0.1
GOONING_MCP_PORT=8765
